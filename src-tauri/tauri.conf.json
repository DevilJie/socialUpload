{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "social-auto-upload-web-ui",
  "version": "0.4.0",
  "identifier": "com.social-auto-upload-web-ui.app",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Social Auto Upload Web UI",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../python": "python",
      "../backend": "backend",
      "bundle-resources/cloakbrowser": "cloakbrowser",
      "../frontend/dist": "frontend"
    },
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}